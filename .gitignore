# Python cache
__pycache__/
*.pyc
*.pyo

# Generated log files
log_peer_*.log

# Old output files
peer1_out.txt
peer2_out.txt
peer3_out.txt

# Auto-generated piece files (recreated on each run)
peer_1001/piece_*

# Peer 1002 and 1003 working directories (empty on start, filled at runtime)
peer_1002/*
peer_1003/*

# Keep the empty directories tracked by git
!peer_1002/.gitkeep
!peer_1003/.gitkeep
